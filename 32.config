# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox=y
# geoip & geosite 数据支持（数据库需手动下载）
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_unzip=y


CONFIG_PACKAGE_luci-app-ramfree=n
CONFIG_PACKAGE_luci-app-diskman=y
# CONFIG_PACKAGE_luci-app-filetransfer=y # 
CONFIG_PACKAGE_luci-app-ttyd=y
# CONFIG_PACKAGE_samba4-server=y  # Samba 文件共享
# CONFIG_PACKAGE_luci-app-samba4=y  # Samba 的 LuCI 支持
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_autosamba=y



# 网络工具和基本依赖
CONFIG_DEFAULT_kmod-button-hotplug=y
CONFIG_DEFAULT_kmod-nf-nathelper=y
CONFIG_DEFAULT_kmod-ipt-raw=y

CONFIG_PACKAGE_xz=y
CONFIG_PACKAGE_xz-utils=y
CONFIG_PACKAGE_liblzma=y

CONFIG_PACKAGE_libopenssl=y
CONFIG_PACKAGE_zlib=y
CONFIG_PACKAGE_libstdcpp=y
