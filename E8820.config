CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7620=y
CONFIG_TARGET_ramips_mt7620_DEVICE_phicomm_k2-v22.4=y

# 基础系统

CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_uci=y

# LuCI（精简版）

CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-light=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y

# 网络基础

CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip6tables-nft=y

# IPv6（全协议）

CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_ipv6helper=y

# PPP

CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y

# 无线

CONFIG_PACKAGE_kmod-mt76-core=y
CONFIG_PACKAGE_kmod-mt76x2=y
CONFIG_PACKAGE_wpad-basic-mbedtls=y

# USB（可选，K2一般不用）

CONFIG_PACKAGE_kmod-usb-core=n

# 存储优化

CONFIG_TARGET_ROOTFS_PARTSIZE=64

# DNS优化

CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_https-dns-proxy=y

# QoS（建议保留但默认不用）

CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-sched-cake=y

# 常用工具

CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_nano=y

# 去掉大体积组件

CONFIG_PACKAGE_openssh-server=n
CONFIG_PACKAGE_openssl-util=n
CONFIG_PACKAGE_python3=n
CONFIG_PACKAGE_lua=n

# 压缩优化

CONFIG_TARGET_SQUASHFS=y
CONFIG_TARGET_IMAGES_GZIP=y

# 广告拦截
CONFIG_PACKAGE_adbyby=n
CONFIG_PACKAGE_luci-app-adbyby-plus=n
CONFIG_PACKAGE_luci-i18n-adbyby-plus-zh-cn=n

CONFIG_PACKAGE_luci-app-filetransfer=n
# 内存释放
CONFIG_PACKAGE_luci-app-ramfree=n

CONFIG_PACKAGE_terminfo=n
# CPU 频率调节和 CPU 限制应用
CONFIG_PACKAGE_luci-app-cpulimit=n


# 网络加速器
CONFIG_PACKAGE_luci-app-turboacc=n
# CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOADING=n

CONFIG_PACKAGE_htop=n
CONFIG_PACKAGE_automount=n
CONFIG_PACKAGE_openssh-sftp-server=n

# 防出错IPV6
CONFIG_PACKAGE_odhcpd-ipv6only=n
CONFIG_PACKAGE_odhcpd=n

CONFIG_PACKAGE_luci-app-serverchan=n
CONFIG_PACKAGE_luci-theme-material=n
CONFIG_PACKAGE_luci-app-sqm=n
CONFIG_PACKAGE_luci-app-eqos=n

# 管理 ARP 绑定IP绑定
CONFIG_PACKAGE_luci-app-arpbind=n
# 上网时间控制
CONFIG_PACKAGE_luci-app-accesscontrol=n

CONFIG_PACKAGE_luci-app-adbyby-plus=n
CONFIG_PACKAGE_luci-app-unblockmusic=n
CONFIG_PACKAGE_luci-app-vlmcsd=n
CONFIG_PACKAGE_luci-app-ddns=n
CONFIG_PACKAGE_luci-app-wol=n

CONFIG_PACKAGE_luci-app-vsftpd=n
CONFIG_PACKAGE_luci-app-zerotier=n
CONFIG_PACKAGE_luci-app-upnp=n

CONFIG_PACKAGE_luci-app-firewall=n
CONFIG_PACKAGE_luci-app-nlbwmon=n
CONFIG_PACKAGE_luci-app-ramfree=n
CONFIG_PACKAGE_luci-app-ttyd=n


# 精简，去掉 NAS/Docker
CONFIG_PACKAGE_samba4=n
CONFIG_PACKAGE_docker=n
CONFIG_PACKAGE_luci-app-dockerman=n
